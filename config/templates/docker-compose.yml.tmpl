# Core Node Docker Compose Configuration
# Generated by core-node setup wizard
# Template version: 3.0

services:
  {{CONTAINER_NAME}}:
    image: {{IMAGE_NAME}}
    container_name: {{CONTAINER_NAME}}
    command: >
      {{CORE_COMMAND}}
    volumes:
      - {{CONFIG_DIR}}:/opt/core/config
      - {{DATA_DIR}}:/opt/core/data
      - {{LOGS_DIR}}:/opt/core/logs
      - {{SNAPSHOTS_DIR}}:/opt/core/data/snapshots
{{TMPFS_VOLUMES}}
{{EXTRA_VOLUMES}}
    network_mode: host
    security_opt:
      - seccomp:unconfined
    restart: {{RESTART_POLICY}}
    stop_grace_period: {{STOP_GRACE_PERIOD}}
{{HEALTHCHECK}}
{{ENVIRONMENT}}

{{GATEWAY_SERVICE}}
